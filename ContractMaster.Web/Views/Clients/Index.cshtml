@model IEnumerable<ContractMaster.Web.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-users"></i> Clients</h1>
        <a href="/Clients/Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New Client
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No clients found. Click "Add New Client" to create one.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Contact Email</th>
                        <th>Region</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model)
                    {
                        <tr>
                            <td>@client.ClientId</td>
                            <td>@client.Name</td>
                            <td>@client.ContactDetails</td>
                            <td>@client.Region</td>
                            <td>
                                <a href="/Clients/Edit/@client.ClientId" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a href="/Clients/Delete/@client.ClientId" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>