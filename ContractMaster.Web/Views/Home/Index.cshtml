@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4">
        <i class="fas fa-tachometer-alt"></i> Dashboard
    </h1>

    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary card-stats">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Clients</h6>
                            <h2 class="mb-0">@ViewBag.TotalClients</h2>
                        </div>
                        <i class="fas fa-users fa-3x opacity-50"></i>
                    </div>
                </div>
                <a href="/Clients" class="card-footer text-white text-decoration-none">
                    View Details <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success card-stats">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Contracts</h6>
                            <h2 class="mb-0">@ViewBag.TotalContracts</h2>
                        </div>
                        <i class="fas fa-file-contract fa-3x opacity-50"></i>
                    </div>
                </div>
                <a href="/Contracts" class="card-footer text-white text-decoration-none">
                    View Details <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info card-stats">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Active Contracts</h6>
                            <h2 class="mb-0">@ViewBag.ActiveContracts</h2>
                        </div>
                        <i class="fas fa-check-circle fa-3x opacity-50"></i>
                    </div>
                </div>
                <a href="/Contracts?status=Active" class="card-footer text-white text-decoration-none">
                    View Details <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning card-stats">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Service Requests</h6>
                            <h2 class="mb-0">@ViewBag.TotalRequests</h2>
                        </div>
                        <i class="fas fa-tools fa-3x opacity-50"></i>
                    </div>
                </div>
                <a href="/ServiceRequests" class="card-footer text-white text-decoration-none">
                    View Details <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <i class="fas fa-bolt"></i> Quick Actions
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/Clients/Create" class="btn btn-outline-primary">
                            <i class="fas fa-user-plus"></i> Add New Client
                        </a>
                        <a href="/Contracts/Create" class="btn btn-outline-success">
                            <i class="fas fa-file-signature"></i> Create New Contract
                        </a>
                        <a href="/Contracts" class="btn btn-outline-info">
                            <i class="fas fa-search"></i> Search Contracts
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <i class="fas fa-info-circle"></i> System Information
                </div>
                <div class="card-body">
                    <p><strong>ContractMaster CMS</strong></p>
                    <p>Version: 2.0 (Monolith)</p>
                    <p>Database: SQL Server LocalDB</p>
                    <p>Currency API: ExchangeRate-API</p>
                    <hr>
                    <small class="text-muted">
                        <i class="fas fa-check-circle text-success"></i> Unit Tests: All Passing
                        <br>
                        <i class="fas fa-lock text-success"></i> File Validation: PDF Only
                        <br>
                        <i class="fas fa-exchange-alt text-success"></i> Auto Currency Conversion
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>