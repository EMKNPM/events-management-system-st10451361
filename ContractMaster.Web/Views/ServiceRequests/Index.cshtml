@using ContractMaster.Web.Models
@model IEnumerable<ContractMaster.Web.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="container mt-4">
    <h1><i class="fas fa-tools"></i> Service Requests</h1>

    <div class="mb-3">
        <a href="/Contracts" class="btn btn-primary">
            <i class="fas fa-arrow-left"></i> Back to Contracts
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No service requests found. Go to a contract and click "Request" to create one.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Contract ID</th>
                        <th>Client</th>
                        <th>Description</th>
                        <th>Cost (USD)</th>
                        <th>Cost (ZAR)</th>
                        <th>Status</th>
                        <th>Created Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>@request.ServiceRequestId</td>
                            <td>@request.ContractId</td>
                            <td>@(request.Contract?.Client?.Name ?? "N/A")</td>
                            <td>@request.Description</td>
                            <td>$@request.CostUSD.ToString("F2")</td>
                            <td>R@request.CostZAR.ToString("F2")</td>
                            <td><span class="badge bg-primary">@request.Status</span></td>
                            <td>@request.CreatedAt.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>