@model ContractMaster.Web.Models.Contract
@{
    ViewData["Title"] = "Contract Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4><i class="fas fa-file-contract"></i> Contract Details</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Contract ID</dt>
                        <dd class="col-sm-9">@Model.ContractId</dd>

                        <dt class="col-sm-3">Client</dt>
                        <dd class="col-sm-9">@Model.Client?.Name</dd>

                        <dt class="col-sm-3">Start Date</dt>
                        <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

                        <dt class="col-sm-3">End Date</dt>
                        <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            <span class="badge @(Model.Status == ContractMaster.Web.Models.ContractStatus.Active ? "bg-success" :
                                                                                                                     Model.Status == ContractMaster.Web.Models.ContractStatus.Expired ? "bg-danger" :
                                                                                                                     Model.Status == ContractMaster.Web.Models.ContractStatus.OnHold ? "bg-warning" : "bg-secondary")">
                                @Model.Status
                            </span>
                        </dd>

                        <dt class="col-sm-3">Service Level</dt>
                        <dd class="col-sm-9">@Model.ServiceLevel</dd>

                        <dt class="col-sm-3">Signed Agreement</dt>
                        <dd class="col-sm-9">
                            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                            {
                                <a href="/Contracts/DownloadAgreement/@Model.ContractId" class="btn btn-sm btn-info">
                                    <i class="fas fa-download"></i> Download PDF
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">No file uploaded</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <a href="/Contracts" class="btn btn-secondary">Back to List</a>
                    @if (Model.Status == ContractMaster.Web.Models.ContractStatus.Active ||
                         Model.Status == ContractMaster.Web.Models.ContractStatus.Draft)
                    {
                        <a href="/ServiceRequests/Create/@Model.ContractId" class="btn btn-success">
                            <i class="fas fa-plus"></i> Create Service Request
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>